# ─── Supabase ────────────────────────────────────────────────────────────────
# Your Supabase project URL (found in: Project Settings → API)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase anonymous/public key (found in: Project Settings → API → anon public)
# This key is safe to expose in the browser — it is scoped by Row Level Security.
VITE_SUPABASE_ANON_KEY=eyJhbGci...
